# VM2026 API runtime configuration
API_PORT=4174

# Required in production
ACCESS_CODE_SALT=replace-with-random-long-string
ADMIN_ACCESS_CODE=replace-with-strong-admin-code

# Optional
ADMIN_ACCESS_NAME=Admin
NODE_ENV=development
# Comma-separated allowed CORS origins (defaults to localhost:4173,localhost:5173)
CORS_ORIGINS=https://your-domain.example.com
